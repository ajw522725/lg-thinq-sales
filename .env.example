# ================================
# LG ThinQ-Sales 환경변수 예시
# 실제 값으로 채운 뒤 .env로 복사
# ================================

# LLM API (둘 중 하나 사용)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# 사용할 LLM provider: "openai" | "gemini" | "demo"
LLM_PROVIDER=demo

# 사용할 모델명
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# Database
DATABASE_URL=postgresql+psycopg://lg_thinq:lg_thinq@localhost:5432/lg_thinq_sales

# Demo 모드 (API key 없이 샘플 데이터로 동작)
DEMO_MODE=true

# NLP 설정
NLP_BATCH_SIZE=32
NLP_MAX_LENGTH=512
TOPIC_MODEL_MIN_DOCS=10

# 로그 레벨
LOG_LEVEL=INFO
