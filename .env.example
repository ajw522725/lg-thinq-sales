# ================================
# LG ThinQ-Sales 환경변수 예시
# 실제 값으로 채운 뒤 .env로 복사
# ================================

# ── Demo Mode ─────────────────────────────────────────────────
# true 로 설정하면 실제 API 없이 data/demo/ 샘플 데이터로 시연 가능
USE_DEMO_DATA=true
DEMO_MODE=true

# ── LLM API ───────────────────────────────────────────────────
# 둘 중 하나 사용
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# 사용할 LLM provider: "openai" | "gemini" | "demo"
LLM_PROVIDER=demo

# 사용할 모델명
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-1.5-pro

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://lg_thinq:lg_thinq@localhost:5432/lg_thinq_sales

# ── Reddit API ────────────────────────────────────────────────
# https://www.reddit.com/prefs/apps 에서 발급
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=lg-thinq-sales/1.0 by wldnjsrla085

# ── Naver Search API ──────────────────────────────────────────
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── YouTube Data API ──────────────────────────────────────────
# https://console.cloud.google.com 에서 발급
YOUTUBE_API_KEY=

# ── X (Twitter) API ───────────────────────────────────────────
# MVP에서는 stub 처리 — 실제 키 없어도 동작
TWITTER_BEARER_TOKEN=

# ── NLP 설정 ──────────────────────────────────────────────────
NLP_BATCH_SIZE=32
NLP_MAX_LENGTH=512
TOPIC_MODEL_MIN_DOCS=10

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
