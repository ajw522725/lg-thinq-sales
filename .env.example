# ── Demo Mode ─────────────────────────────────────────────────
# true 로 설정하면 실제 API 없이 data/demo/ 샘플 데이터로 시연 가능
USE_DEMO_DATA=true

# ── Reddit API ────────────────────────────────────────────────
# https://www.reddit.com/prefs/apps 에서 발급
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=lg-thinq-sales/1.0 by wldnjsrla085

# ── Naver Search API ──────────────────────────────────────────
# https://developers.naver.com/apps 에서 발급
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── YouTube Data API ──────────────────────────────────────────
# https://console.cloud.google.com 에서 발급
YOUTUBE_API_KEY=

# ── X (Twitter) API ───────────────────────────────────────────
# MVP에서는 stub 처리 — 실제 키 없어도 동작
TWITTER_BEARER_TOKEN=

# ── LLM API (Phase 2 이후) ────────────────────────────────────
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/lg_thinq_sales

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
